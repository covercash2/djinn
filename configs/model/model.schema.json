{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ModelConfig",
  "description": "Configurations that are loaded on initialization of the model.",
  "type": "object",
  "required": [
    "flash_attn",
    "model_source",
    "variant"
  ],
  "properties": {
    "device": {
      "default": "Cpu",
      "allOf": [
        {
          "$ref": "#/definitions/Device"
        }
      ]
    },
    "flash_attn": {
      "description": "Set true to use flash attention. Only supported on CUDA",
      "type": "boolean"
    },
    "model_source": {
      "$ref": "#/definitions/ModelSource"
    },
    "variant": {
      "$ref": "#/definitions/ModelArchitecture"
    }
  },
  "definitions": {
    "Device": {
      "description": "A enum of supported devices to run models on",
      "type": "string",
      "enum": [
        "Cpu",
        "Cuda",
        "Metal"
      ]
    },
    "ModelArchitecture": {
      "description": "The variant of the model to be loaded",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "distil_bert",
            "starcoder"
          ]
        },
        {
          "description": "Main Mistral version",
          "type": "string",
          "enum": [
            "mistral"
          ]
        },
        {
          "description": "Quantized Mistral",
          "type": "string",
          "enum": [
            "q_mistral"
          ]
        }
      ]
    },
    "ModelSource": {
      "description": "Where to load the model from, either HuggingFaceHub or from the file system",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "hugging_face_hub"
          ],
          "properties": {
            "hugging_face_hub": {
              "type": "object",
              "required": [
                "revision"
              ],
              "properties": {
                "revision": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "files"
          ],
          "properties": {
            "files": {
              "type": "object",
              "required": [
                "tokenizer_file",
                "weight_files"
              ],
              "properties": {
                "tokenizer_file": {
                  "type": "string"
                },
                "weight_files": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}